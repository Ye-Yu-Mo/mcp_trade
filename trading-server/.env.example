# Trading Server 环境变量配置模板
# 复制此文件为 .env 并填入真实值: cp .env.example .env

# 环境: testnet | mainnet (默认 testnet)
TRADE_ENV=testnet

# Binance API 凭据
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# HTTP 服务端口 (默认 8877)
SERVER_PORT=8877

# DuckDB 数据库路径 (默认 data/trade.duckdb)
DB_PATH=data/trade.duckdb
